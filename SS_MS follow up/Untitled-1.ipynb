    "\n",
    "p = r * np.exp(-(1500. - r) / 90.)\n",
    "\n",
    "\n",
    "plt.plot(r, p)\n",
    "\n",
    "plt.yscale('log')\n",
    "\n",
    "plt.xlabel('Radius [mm]')\n",
    "\n",
